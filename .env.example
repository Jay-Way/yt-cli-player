# Path to your Google OAuth client secret JSON.
# Download from: Google Cloud Console > APIs & Services > Credentials
# Default: ~/.config/yt-cli-player/client_secret.json
# YOUTUBE_CLIENT_SECRET_PATH=/path/to/client_secret.json

# Show real-time equalizer bars in the now-playing panel (requires cava).
# SHOW_VISUALIZER=true

# Show album art as Unicode block art in the now-playing panel (requires chafa).
# SHOW_THUMBNAIL=false
